# ============================================================
# VARIABLES D'ENVIRONNEMENT — Site web (Next.js)
# Copiez ce fichier en ".env.local" pour le développement local,
# et reportez ces mêmes valeurs dans les "Environment Variables" de Vercel
# ============================================================

# --- Supabase ---
# À récupérer dans Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx...votre_clé_anon
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx...votre_clé_service_role   # SECRÈTE, jamais exposée au navigateur

# --- OpenAI ---
# À récupérer sur https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Bot Telegram ---
# Secret partagé entre le site et le bot, inventez une longue chaîne aléatoire
BOT_API_SECRET=changez-moi-par-une-longue-chaine-aleatoire-secrete
